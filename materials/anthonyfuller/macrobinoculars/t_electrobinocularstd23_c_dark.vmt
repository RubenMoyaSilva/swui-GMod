"VertexLitGeneric"
{
	$basetexture 	"anthonyfuller/macrobinoculars/t_electrobinocularstd23_c_dark"
	$bumpmap 	"anthonyfuller/macrobinoculars/t_electrobinocularsdt23_c_n"

	"$phong" "1"


	"$phongboost" "2"
	"$phongalbedoboost" "25"
	"$phongfresnelranges" "[.83 .83 1]"

	"$basemapalphaphongmask" "1"

	"$phongalbedotint" "1"

	"$phongdisablehalflambert" "1"

	"$envmap" "env_cubemap"
	"$envmapfresnel" "1"
	"$envmaptint" 		"[.05 .05 .05]"



}
